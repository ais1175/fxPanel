        "d3-array": "^3.2.4",
        "dateformat": "^5.0.3",
        "discord.js": "^14.26.2",
        "ejs": "^3.1.10",
        "error-stack-parser": "^2.1.4",
        "esbuild": "0.28.0",
        "fuse.js": "^7.0.0",
        "got": "^13.0.0",
        "is-localhost-ip": "^2.0.0",
        "jose": "^4.15.4",
        "js-yaml": "^4.1.0",
        "koa": "^2.15.4",
        "koa-bodyparser": "^4.4.1",
