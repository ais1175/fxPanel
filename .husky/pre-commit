#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Check for !NC tags in staged changes
# These are TO-DO markers that must be resolved before committing
NC_MATCHES=$(git diff --cached --unified=0 --no-color | grep '^+' | grep '!NC' || true)
if [ -n "$NC_MATCHES" ]; then
    echo ""
    echo "ERROR: Found !NC tags in staged changes that must be resolved before committing:"
    echo "$NC_MATCHES"
    echo ""
    exit 1
fi
