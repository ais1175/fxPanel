{
    "name": "fxPanel-nui",
    "version": "0.2.2",
    "description": "The NUI package contains all the in-game interface (menu and warn page) of fxPanel.",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "build": "vite build --mode production",
        "dev": "vite build --watch --mode development",
        "browser": "vite dev --port 40121 --strictPort --mode devNuiBrowser",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "license:report": "npx license-report > ../.reports/license/nui.html"
    },
    "keywords": [],
    "author": "SomeAussieGaymer",
    "license": "MIT",
    "dependencies": {
        "@emotion/react": "^11.13.3",
        "@emotion/styled": "^11.13.0",
        "@fontsource-variable/inter": "^5.2.8",
        "@mui/icons-material": "^6.1.2",
        "@mui/material": "6.1.2",
        "jotai": "^2.19.1",
        "nanoid": "5.1.7",
        "notistack": "^3.0.1",
        "react-polyglot": "^0.7.2"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.1.5",
        "@testing-library/react": "^14.1.2",
        "@testing-library/user-event": "^14.5.1",
        "@types/node-polyglot": "^2.5.0",
        "@types/react": "^18.3.11",
        "@types/react-dom": "^18.3.0",
        "@types/testing-library__jest-dom": "^6.0.0",
        "@vitejs/plugin-react-swc": "^3.7.1",
        "@vitest/ui": "^4.1.2",
        "jsdom": "^23.0.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "vite": "^8.0.5",
        "vite-tsconfig-paths": "^5.0.1",
        "vitest": "^4.1.2"
    }
}
