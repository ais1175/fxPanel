{
    "compilerOptions": {
        "target": "ES6",
        "useDefineForClassFields": true,
        "lib": ["DOM", "DOM.Iterable", "ES6"],
        "allowJs": false,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ES6",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "types": ["node"],

        /* mod resolution. */
        "paths": {
            "@shared/*": ["../shared/*"],
            "@locale/*": ["../locale/*"],
            "@nui/*": ["./*"]
        }
    },
    "include": ["src"]
}
