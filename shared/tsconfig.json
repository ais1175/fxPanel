{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "composite": true,

        "module": "ES2020",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "outDir": "../.tsc/shared",

        "rootDir": "../",
        "paths": {
            "@core/*": ["../core/*"],
            "@locale/*": ["../locale/*"]
        }
    },
    "include": ["**/*", "../locale/*.json"],
    "references": [{ "path": "../core" }]
}
