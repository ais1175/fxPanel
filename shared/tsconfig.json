{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "composite": true,

        "module": "ES2020",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "types": ["node"],
        "outDir": "../.tsc/shared",

        "rootDir": "../",
        "paths": {
            "@locale/*": ["../locale/*"]
        }
    },
    "include": ["**/*", "../locale/*.json"]
}
